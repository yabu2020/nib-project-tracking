# ===========================
# ADD TO YOUR EXISTING .gitignore
# ===========================

# ===========================
# REACT / NODE / FRONTEND
# ===========================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.pnp.js

# Build outputs
build/
dist/
out/

# Environment files (SECURITY - NEVER COMMIT)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# ===========================
# DATABASE / CONFIG (SECURITY!)
# ===========================
# NEVER commit production configs or secrets
src/main/resources/application-prod.properties
src/main/resources/application-prod.yml
src/main/resources/application-prod.yaml
*.pem
*.key
*.crt
secrets/
config/production/
config/prod/

# ===========================
# LOGS & TEMP
# ===========================
logs/
*.log
temp/
tmp/
*.tmp

# ===========================
# PERSONAL / LOCAL OVERRIDES
# ===========================
*.local.*
local.properties
*.local.properties